# Server
PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://user:pass@host:5432/shopflow_webhook_router
DB_SSL=false

# Meta TSP App — the single App all Shopflow installations share
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Embedded-signup proxy (optional). When set, /embedded-signup/start serves a
# page that loads the FB JS SDK on this router's domain (the only domain you
# need to whitelist in Meta App Dashboard → JavaScript SDK host domains) and
# relays the auth code + WABA metadata back to each Shopflow install via
# window.opener.postMessage. The router never sees the auth code.
META_APP_ID=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_SOLUTION_ID=
META_GRAPH_VERSION=v21.0

# Fanout behaviour
FORWARD_TIMEOUT_MS=4000
FORWARD_MAX_RETRIES=6
DISPATCH_TICK_MS=15000
